<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>All genereted Short URLs</h2>
    <p>
    <% urls.forEach((url) => { %>
        <li><%= url.shortId %> : <%= url.originalUrl %></li> 
    <% }) %>
    </p>
    <h2>Total visits on each URL</h2>
    <p><% urls.forEach((url) => { %>
        <li> <a href="http://localhost:3000/api/shorturl/<%= url.shortId %>"><%= url.shortId %></a> : <%= url.originalUrl %> : <%= url.visitHistory.length %></li> 
    <% }) %></p>
</body>
</html>