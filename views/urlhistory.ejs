<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My URL History</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
    <div class="header-links">
        <a href="/">← Back to Home</a>
        <div style="flex-grow: 1;"></div>
        <div>User: <strong><%= user.username %></strong></div>
    </div>

    <h1>My URL History</h1>
    
    <% if (locals.error) { %>
        <div class="error"><%= error %></div>
    <% } %>

    <% if (urls && urls.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Short ID</th>
                    <th>Original URL</th>
                    <th>Clicks</th>
                    <th>Expires</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% urls.forEach((url) => { %>
                    <tr>
                        <td><strong><%= url.shortId %></strong></td>
                        <td>
                            <a href="<%= url.originalUrl %>" target="_blank" style="max-width: 200px; display: inline-block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                <%= url.originalUrl %>
                            </a>
                        </td>
                        <td><%= url.totalVisits %></td>
                        <td><%= url.expiresAt ? new Date(url.expiresAt).toLocaleDateString() : '-' %></td>
                        <td><%= new Date(url.createdAt).toLocaleDateString() %></td>
                        <td>
                            <a href="/analytics/<%= url.shortId %>" style="margin-right: 10px;">Analytics</a>
                            <button class="danger" onclick="deleteUrl('<%= url.shortId %>')">Delete</button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>You haven't shortened any URLs yet.</p>
    <% } %>

    <script>
        async function deleteUrl(shortId) {
            if (!confirm('Are you sure you want to delete this short URL?')) return;
            try {
                const res = await fetch(`/api/shorturl/${shortId}`, { method: 'DELETE' });
                const json = await res.json();
                if (json.success) {
                    window.location.reload();
                } else {
                    alert('Error deleting URL: ' + (json.error || 'Unknown error'));
                }
            } catch (err) {
                alert('Server error occurred.');
            }
        }
    </script>
</div>
</body>
</html>