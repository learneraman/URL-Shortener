<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>URL Shortener</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
    <div class="header-links">
        <div>Welcome, <strong><%= user.username %></strong></div>
        <div style="flex-grow: 1;"></div>
        <a href="/urlhistory">History</a>
        <a href="/api/auth/logout">Logout</a>
    </div>

    <h1>Shorten a New URL</h1>

    <form action="/api/shorturl" method="POST">
        <label>Long URL:</label>
        <input type="text" name="url" placeholder="https://example.com/very/long/url" autofocus>

        <label>Custom Slug (optional):</label>
        <input type="text" name="customSlug" placeholder="my-custom-link">

        <label>Expires in days (optional):</label>
        <input type="number" name="expiryDays" min="1" max="365" placeholder="e.g. 7">

        <button type="submit">Shorten URL</button>
    </form>

    <% if (locals.error) { %>
        <div class="error"><strong>Error:</strong> <%= error %></div>
    <% } %>

    <% if (locals.shortID) { %>
        <div class="success-box">
            <h3>🎉 URL Shortened!</h3>
            <p><strong>Short ID:</strong> <%= shortID %></p>
            <p><strong>Redirect URL:</strong>
                <a href="/api/shorturl/<%= shortID %>" target="_blank" id="shortUrlLink">
                    /api/shorturl/<%= shortID %>
                </a>
            </p>
            <% if (locals.message) { %><p><em><%= message %></em></p><% } %>
            <% if (locals.expiresAt) { %><p><strong>Expires:</strong> <%= new Date(expiresAt).toLocaleDateString() %></p><% } %>
            <p style="margin-top: 1rem;"><a href="/analytics/<%= shortID %>">View Analytics →</a></p>
        </div>
    <% } %>
</div>
<script>
    // 1. Convert relative link to full domain link dynamically 
    const link = document.getElementById('shortUrlLink');
    if (link) {
        link.textContent = window.location.origin + link.getAttribute('href');
        link.href = window.location.origin + link.getAttribute('href');
    }

    // 2. Clear ?error= or ?shortID= from the browser URL address bar
    //    so that a page refresh (F5) doesn't show the error/success banner again.
    if (window.history.replaceState && window.location.search) {
        window.history.replaceState(null, null, window.location.pathname);
    }
</script>
</body>
</html>