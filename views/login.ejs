<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login — URL Shortener</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container" style="max-width: 400px; margin-top: 4rem;">
    <h1 style="text-align: center;">Login</h1>

    <% if (locals.error) { %>
        <div class="error"><%= error %></div>
    <% } %>

    <form action="/api/auth/login" method="POST">
        <label>Email:</label>
        <input type="email" name="email" required autofocus>

        <label>Password:</label>
        <input type="password" name="password" required>

        <button type="submit" style="width: 100%; margin-top: 1rem;">Login</button>
    </form>

    <div style="text-align: center; margin-top: 2rem; font-size: 0.95rem;">
        Don't have an account? <a href="/signup">Sign up here</a>
    </div>
</div>
</body>
</html>
