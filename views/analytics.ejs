<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Analytics - <%= data.shortId %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
    <div class="header-links">
        <a href="/urlhistory">← Back to History</a>
        <div style="flex-grow: 1;"></div>
        <div>Analytics: <strong><%= data.shortId %></strong></div>
    </div>

    <h1>URL Analytics</h1>
    
    <div class="success-box" style="margin-top: 1rem;">
        <p><strong>Original URL:</strong> <a href="<%= data.originalUrl %>" target="_blank"><%= data.originalUrl %></a></p>
        <p><strong>Total Visits:</strong> <%= data.totalVisits %></p>
        <p><strong>Created:</strong> <%= new Date(data.createdAt).toLocaleString() %></p>
        <p><strong>Last Visited:</strong> <%= data.lastVisited ? new Date(data.lastVisited).toLocaleString() : 'Never' %></p>
        <p><strong>Expires:</strong> <span style="color: var(--danger);"><%= data.expiresAt ? new Date(data.expiresAt).toLocaleString() : 'Never' %></span></p>
    </div>

    <h2 style="margin-top: 2.5rem;">Recent Visits (Last 10)</h2>
    <% if (data.recentVisits && data.recentVisits.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Visit #</th>
                    <th>Timestamp (Local Time)</th>
                    <th>OS</th>
                    <th>Device</th>
                </tr>
            </thead>
            <tbody>
                <% data.recentVisits.slice().reverse().forEach((visit, index) => { %>
                    <tr>
                        <td><strong><%= index + 1 %></strong></td>
                        <td><%= new Date(visit.timestamp).toLocaleString() %></td>
                        <td><%= visit.os || 'Unknown' %></td>
                        <td><%= visit.device || 'Desktop' %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p style="color: #64748b; font-style: italic;">No visits recorded yet.</p>
    <% } %>
</div>
</body>
</html>
